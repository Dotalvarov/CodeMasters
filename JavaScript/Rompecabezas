        if (idFig.length == 2) {
            idFig = idFig.charAt(1);
        } else {
            idFig = padres[i].getAttribute("id");
        }
  
        if (origX[idFig] == posx && origY[idFig] == posy) {
           ubicada = ubicada + 1;
           //document.getElementById("puntos").textContent = "Puntaje: " + ubicada;
